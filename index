<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>大島紬 締め管理 v7.1 (OCR対応)</title>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap');
        body { font-family: 'Noto Sans JP', sans-serif; background-color: #f8fafc; }
        .input-label { display: block; font-size: 0.75rem; font-weight: bold; color: #475569; margin-bottom: 0.25rem; margin-top: 0.75rem; }
        .form-input { width: 100%; border: 1px solid #cbd5e1; padding: 0.7rem; border-radius: 0.5rem; background: white; font-size: 0.9rem; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        const SHIME_MEMBERS = ["小江", "川井", "前島", "友松"];
        const ITOBETSUS = ["絣緯", "地緯", "絣経"];
        const DIFF_LEVELS = ["低", "中", "高"];

        const addWorkDays = (startDateStr, daysToAdd) => {
            let date = new Date(startDateStr);
            if (isNaN(date.getTime())) return "エラー";
            let addedDays = 0;
            while (addedDays < daysToAdd) {
                date.setDate(date.getDate() + 1);
                if (date.getDay() !== 0) addedDays++;
            }
            return date.toISOString().split('T')[0];
        };

        function App() {
            const [tab, setTab] = useState('進行');
            const [records, setRecords] = useState([]);
            const [editingId, setEditingId] = useState(null);

            // Gemini API用のステート
            const [apiKey, setApiKey] = useState(localStorage.getItem('gemini-api-key') || '');
            const [isProcessing, setIsProcessing] = useState(false);
            const [showKeyInput, setShowKeyInput] = useState(false);

            const initialForm = {
                gara_ban: '', gara_name: '', 
                gara_main_type: '白', gara_keito_type: '一元', gara_kousei_type: '総絣',
                itobetsu: '絣緯', shime_name: SHIME_MEMBERS[0],
                shinasu: '', sagari: '', maruki: '',
                itowatashi_date: new Date().toISOString().split('T')[0],
                completion_date: '', wage: '',
                nuki_rank: '中', hosu_score: 3, maisu_score: 3, note: ''
            };
            const [formData, setFormData] = useState(initialForm);

            useEffect(() => {
                const saved = localStorage.getItem('oshimatsumugi-v7');
                if (saved) setRecords(JSON.parse(saved));
            }, []);

            useEffect(() => {
                localStorage.setItem('oshimatsumugi-v7', JSON.stringify(records));
            }, [records]);

            const getScheduledDate = (shimeName, itobetsu, startDate) => {
                const past = records.filter(r => r.shime_name === shimeName && r.itobetsu === itobetsu && r.completion_date);
                let avgDays = 30;
                if (past.length > 0) {
                    const totalDays = past.reduce((sum, r) => {
                        const s = new Date(r.itowatashi_date), e = new Date(r.completion_date);
                        return sum + Math.round((e - s) / 86400000);
                    }, 0);
                    avgDays = Math.max(1, Math.round(totalDays / past.length));
                }
                return addWorkDays(startDate, avgDays);
            };

            // 画像解析・自動入力のメイン処理
            const handleImageChange = async (e) => {
                const file = e.target.files[0];
                if (!file) return;
                if (!apiKey) {
                    alert("先にGemini APIキーを設定してくれってばよ！");
                    return;
                }

                setIsProcessing(true);
                try {
                    // 画像をBase64に変換
                    const base64Data = await new Promise((resolve) => {
                        const reader = new FileReader();
                        reader.onloadend = () => resolve(reader.result.split(',')[1]);
                        reader.readAsDataURL(file);
                    });

                    // Gemini 1.5 Flash APIの呼び出し
                    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            contents: [{
                                parts: [
                                    { text: "この画像は大島紬の製造管理用の指示書、またはメモだ。写っている文字を解析し、以下の項目を特定して指定のJSONフォーマットのみで返却せよ。該当情報が見つからない項目は空文字にせよ。解説やマークダウン（
http://googleusercontent.com/immersive_entry_chip/0

---

## 使い方

1. **APIキーの取得**
   Google AI Studio（無料）にアクセスし、Googleアカウントでログインして「Get API key」からキーを発行する。
2. **アプリでの設定**
   アプリを起動し、「管理」タブを開く。上部にある「APIキー設定」リンクを叩いて、発行したキー（`AIzaSy...` から始まる文字列）を貼り付ける。一度入力すればスマホのブラウザに記憶される。
3. **撮影・自動入力**
   「画像を読み込む」を叩くと、スマホのカメラが起動するかファイル選択が開く。伝票やメモの写真を撮れば、AIが自動解析して**柄番・柄名・マルキ数・品数・サガリ**をフォームへ一瞬で流し込むぞ！
